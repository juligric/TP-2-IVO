---
// Página de login - acá el usuario pone su email y contraseña para entrar
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: system-ui, sans-serif;
        background: #f0f4f8;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .card {
        background: white;
        border-radius: 16px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 380px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        text-align: center;
      }

      .logo-icon {
        background: #1e3a5f;
        color: white;
        width: 50px;
        height: 50px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin: 0 auto 1.2rem;
      }

      h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.4rem; }
      .subtitulo { color: #888; font-size: 0.9rem; margin-bottom: 1.5rem; }

      .error-box {
        background: #fff0f0;
        border: 1px solid #fca5a5;
        color: #b91c1c;
        border-radius: 8px;
        padding: 0.7rem 1rem;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        text-align: left;
        display: none;
      }

      .campo { text-align: left; margin-bottom: 1rem; }
      .campo label { font-size: 0.85rem; color: #555; display: block; margin-bottom: 0.3rem; }
      .campo input {
        width: 100%;
        padding: 0.7rem 1rem;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 0.95rem;
      }
      .campo input:focus { outline: none; border-color: #2563eb; }

      .btn-azul {
        width: 100%;
        background: #2563eb;
        color: white;
        border: none;
        padding: 0.8rem;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        margin-top: 0.5rem;
      }
      .btn-azul:hover { background: #1d4ed8; }

      .link-registro {
        margin-top: 1.2rem;
        font-size: 0.85rem;
        color: #666;
      }
      .link-registro a { color: #2563eb; text-decoration: none; font-weight: 600; }
      .link-registro a:hover { text-decoration: underline; }

      footer { margin-top: 2rem; font-size: 0.8rem; color: #aaa; }
    </style>
  </head>
  <body>

    <div class="card">
      <div class="logo-icon">📚</div>
      <h1>Bienvenido de nuevo</h1>
      <p class="subtitulo">Accedé a tu biblioteca digital personalizada</p>

      <div class="error-box" id="error-msg"></div>

      <form id="login-form">
        <div class="campo">
          <label>Correo Electrónico</label>
          <input type="email" name="email" placeholder="ejemplo@correo.com" required />
        </div>

        <div class="campo">
          <label>Contraseña</label>
          <input type="password" name="password" placeholder="••••••••" required />
        </div>

        <button type="submit" class="btn-azul">Entrar →</button>
      </form>

      <p class="link-registro">
        ¿No tenés una cuenta? <a href="/registro">Registrate gratis</a>
      </p>
    </div>

    <footer>© 2024 Dashboard Libros. Todos los derechos reservados.</footer>

  </body>
</html>

<script>
  import { signIn } from "../lib/auth";

  document.getElementById("login-form")!.addEventListener("submit", async (e) => {
    e.preventDefault();
    const form     = e.target as HTMLFormElement;
    const email    = (form.elements.namedItem("email")    as HTMLInputElement).value;
    const password = (form.elements.namedItem("password") as HTMLInputElement).value;
    const errorBox = document.getElementById("error-msg")!;

    try {
      await signIn(email, password);
      window.location.href = "/";
    } catch (err: any) {
      errorBox.textContent = "⚠ " + err.message;
      errorBox.style.display = "block";
    }
  });
</script>
