---
// Página de registro - acá el usuario crea una cuenta nueva con nombre, email y contraseña
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Crear cuenta — BookShelf</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
      }

      .wrapper {
        display: flex;
        width: 100%;
        max-width: 900px;
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 25px 60px rgba(0,0,0,0.25);
        min-height: 540px;
      }

      /* Panel izquierdo decorativo */
      .panel-izq {
        flex: 1;
        background: linear-gradient(160deg, #4f46e5, #7c3aed);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        color: white;
        text-align: center;
      }
      .panel-izq .logo-box {
        width: 64px; height: 64px;
        background: rgba(255,255,255,0.15);
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem; font-weight: 900;
        margin: 0 auto 1.2rem;
        letter-spacing: -0.03em;
      }
      .panel-izq h2   { font-size: 1.6rem; font-weight: 800; margin-bottom: 0.6rem; }
      .panel-izq p    { font-size: 0.9rem; opacity: 0.8; line-height: 1.6; max-width: 220px; }

      /* Panel derecho */
      .panel-der {
        flex: 1;
        padding: 2.5rem 2.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      h1 { font-size: 1.6rem; font-weight: 800; color: #1e293b; margin-bottom: 0.3rem; }
      .subtitulo { color: #64748b; font-size: 0.9rem; margin-bottom: 1.8rem; }

      .ok-box {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #15803d;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-size: 0.85rem;
        margin-bottom: 1.2rem;
        display: none;
        line-height: 1.5;
      }

      .error-box {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-size: 0.85rem;
        margin-bottom: 1.2rem;
        display: none;
      }

      .campo { margin-bottom: 1rem; }
      .campo label {
        font-size: 0.82rem;
        font-weight: 600;
        color: #475569;
        display: block;
        margin-bottom: 0.4rem;
      }
      .campo input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 0.95rem;
        font-family: inherit;
        transition: border-color 0.15s;
        color: #1e293b;
      }
      .campo input:focus {
        outline: none;
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79,70,229,0.1);
      }
      .hint { font-size: 0.75rem; color: #94a3b8; margin-top: 0.3rem; }

      .btn-principal {
        width: 100%;
        background: #4f46e5;
        color: white;
        border: none;
        padding: 0.85rem;
        border-radius: 10px;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.15s;
        font-family: inherit;
        margin-top: 0.4rem;
      }
      .btn-principal:hover { background: #3730a3; }

      .link-login {
        margin-top: 1.4rem;
        text-align: center;
        font-size: 0.85rem;
        color: #64748b;
      }
      .link-login a {
        color: #4f46e5;
        font-weight: 600;
        text-decoration: none;
      }
      .link-login a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>

    <div class="wrapper">

      <div class="panel-izq">
        <div class="logo-box">BS</div>
        <h2>BookShelf</h2>
        <p>Creá tu cuenta gratis y empezá a construir tu biblioteca personal.</p>
      </div>

      <div class="panel-der">
        <h1>Crear cuenta</h1>
        <p class="subtitulo">Uníte a nuestra comunidad de lectores</p>

        <div class="ok-box" id="ok-msg">
          ✓ ¡Te registraste! Revisá tu email y confirmá tu cuenta antes de iniciar sesión.
        </div>
        <div class="error-box" id="error-msg"></div>

        <form id="registro-form">
          <div class="campo">
            <label>Nombre completo</label>
            <input type="text" name="nombre" placeholder="Ej. Juan Pérez" required />
          </div>
          <div class="campo">
            <label>Email</label>
            <input type="email" name="email" placeholder="correo@ejemplo.com" required />
          </div>
          <div class="campo">
            <label>Contraseña</label>
            <input type="password" name="password" placeholder="••••••••" minlength="6" required />
            <p class="hint">Mínimo 6 caracteres</p>
          </div>
          <button type="submit" class="btn-principal">Registrarse →</button>
        </form>

        <p class="link-login">
          ¿Ya tenés cuenta? <a href="/login">Iniciá sesión</a>
        </p>
      </div>

    </div>

  </body>
</html>

<script>
  import { signUp } from "../lib/auth";

  document.getElementById("registro-form")!.addEventListener("submit", async (e) => {
    e.preventDefault();
    const form     = e.target as HTMLFormElement;
    const nombre   = (form.elements.namedItem("nombre")   as HTMLInputElement).value;
    const email    = (form.elements.namedItem("email")    as HTMLInputElement).value;
    const password = (form.elements.namedItem("password") as HTMLInputElement).value;
    const errorBox = document.getElementById("error-msg")!;
    const okBox    = document.getElementById("ok-msg")!;

    try {
      await signUp(email, password, nombre);
      okBox.style.display = "block";
      errorBox.style.display = "none";
    } catch (err: any) {
      errorBox.textContent = err.message;
      errorBox.style.display = "block";
    }
  });
</script>
